{
  "name": "make-a-wish-guam",
  "version": "1.0.0",
  "private": true,
  "description": "Event registration and management for Make-A-Wish Guam & CNMI charity events",
  "scripts": {
    "api:dev": "cd api && bin/rails server",
    "web:dev": "cd web && npm run dev",
    "dev": "concurrently \"pnpm api:dev\" \"pnpm web:dev\"",
    "build": "cd web && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
