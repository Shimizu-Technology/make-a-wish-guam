# Make-A-Wish Guam API - Environment Variables

# Database
DATABASE_URL=postgresql://localhost/make_a_wish_guam_development

# Redis (for ActionCable)
REDIS_URL=redis://localhost:6379/1

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Payments (existing, may be replaced by CardPointe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SwipeSimple (interim payment solution)
SWIPE_SIMPLE_PAYMENT_URL=https://swipesimple.com/links/lnk_e1c8f45f9c401c93552781ef3d52fdfc

# Resend Email
RESEND_API_KEY=re_xxx
MAILER_FROM_EMAIL=noreply@shimizu-technology.com

# Delivery status callbacks (Resend + ClickSend)
# Add this token to webhook URLs as ?token=...
DELIVERY_WEBHOOK_TOKEN=

# Frontend URL (for CORS, emails)
FRONTEND_URL=http://localhost:5173

# Rails
RAILS_ENV=development
RAILS_MASTER_KEY=
ENABLE_RATE_LIMITING=false

# AWS S3 (Active Storage - production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=
# AWS_S3_BUCKET= # also supported instead of AWS_BUCKET
