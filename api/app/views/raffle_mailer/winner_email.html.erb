<%
  brand = @primary_color || '#0057B8'
  dark_brand = brand.gsub('#', '').tap { |hex|
    break '#000000' unless hex.length == 6 && hex.match?(/\A[0-9A-Fa-f]{6}\z/)
    r = [hex[0..1].to_i(16) * 75 / 100, 0].max
    g = [hex[2..3].to_i(16) * 75 / 100, 0].max
    b = [hex[4..5].to_i(16) * 75 / 100, 0].max
    break "#%02x%02x%02x" % [r, g, b]
  }
  formatted_date = if @tournament.event_date.is_a?(Date)
    @tournament.event_date.strftime('%B %-d, %Y')
  elsif @tournament.event_date.present?
    begin; Date.parse(@tournament.event_date.to_s).strftime('%B %-d, %Y'); rescue; @tournament.event_date; end
  else
    'TBA'
  end
%>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <tr>
    <td align="center" style="padding: 32px 16px;">
      <table role="presentation" width="560" cellspacing="0" cellpadding="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; max-width: 100%;">

        <!-- Header -->
        <tr>
          <td style="background: linear-gradient(135deg, <%= brand %> 0%, <%= dark_brand %> 100%); padding: 32px 32px 28px; text-align: center;">
            <p style="margin: 0 0 6px; color: rgba(255,255,255,0.75); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; font-weight: 600;"><%= @org_name %></p>
            <h1 style="margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; line-height: 1.3;"><%= @tournament.name %></h1>
            <p style="margin: 8px 0 0; color: rgba(255,255,255,0.7); font-size: 13px;">Raffle Drawing</p>
          </td>
        </tr>

        <!-- Winner banner -->
        <tr>
          <td style="padding: 24px 32px 0; text-align: center;">
            <span style="display: inline-block; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: #ffffff; padding: 8px 20px; border-radius: 24px; font-size: 14px; font-weight: 700; letter-spacing: 0.5px;">Congratulations — You're a Winner!</span>
          </td>
        </tr>

        <!-- Greeting -->
        <tr>
          <td style="padding: 24px 32px 0;">
            <p style="margin: 0 0 16px; color: #1a1a1a; font-size: 17px; font-weight: 600;">Hi <%= @prize.winner_name %>,</p>
            <p style="margin: 0 0 20px; color: #4b5563; font-size: 14px; line-height: 1.65;">
              Your raffle ticket was drawn as a winner at <strong style="color: #1a1a1a;"><%= @tournament.name %></strong>!
            </p>
          </td>
        </tr>

        <!-- Prize card -->
        <tr>
          <td style="padding: 0 32px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 100%); border: 1px solid #fde68a; border-radius: 12px; margin-bottom: 20px;">
              <tr>
                <td style="padding: 24px; text-align: center;">
                  <p style="margin: 0 0 6px; color: #92400e; font-size: 11px; text-transform: uppercase; letter-spacing: 2px; font-weight: 600;">You Won</p>
                  <h2 style="margin: 0 0 8px; color: #78350f; font-size: 24px; font-weight: 700;"><%= @prize.name %></h2>
                  <% if @prize.value_cents && @prize.value_cents > 0 %>
                    <p style="margin: 0 0 8px; color: #92400e; font-size: 16px; font-weight: 500;">
                      Value: $<%= (@prize.value_cents / 100).to_s.reverse.gsub(/(\d{3})(?=\d)/, '\\1,').reverse %>
                    </p>
                  <% end %>
                  <% if @prize.description.present? %>
                    <p style="margin: 0; color: #a16207; font-size: 13px; line-height: 1.5;"><%= @prize.description %></p>
                  <% end %>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Winning ticket -->
        <tr>
          <td style="padding: 0 32px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f9fafb; border-radius: 12px; margin-bottom: 20px;">
              <tr>
                <td style="padding: 20px;">
                  <p style="margin: 0 0 8px; color: <%= brand %>; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">Winning Ticket</p>
                  <p style="margin: 0; color: #111827; font-size: 20px; font-weight: 700; font-family: 'Courier New', monospace; letter-spacing: 1px;">
                    #<%= @ticket&.ticket_number || 'N/A' %>
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- How to claim -->
        <tr>
          <td style="padding: 0 32px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f9fafb; border-radius: 12px; margin-bottom: 20px;">
              <tr>
                <td style="padding: 20px;">
                  <p style="margin: 0 0 12px; color: <%= brand %>; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">How to Claim</p>
                  <p style="margin: 0 0 12px; color: #4b5563; font-size: 13px; line-height: 1.6;">
                    Please contact the event organizers to arrange pickup of your prize.
                  </p>
                  <table role="presentation" cellspacing="0" cellpadding="0" width="100%">
                    <% if @tournament.contact_name.present? %>
                    <tr>
                      <td style="padding: 4px 0; color: #6b7280; font-size: 13px; width: 70px;">Contact</td>
                      <td style="padding: 4px 0; color: #111827; font-size: 13px; font-weight: 500;"><%= @tournament.contact_name %></td>
                    </tr>
                    <% end %>
                    <% if @tournament.contact_phone.present? %>
                    <tr>
                      <td style="padding: 4px 0; color: #6b7280; font-size: 13px;">Phone</td>
                      <td style="padding: 4px 0; color: #111827; font-size: 13px; font-weight: 500;"><%= @tournament.contact_phone %></td>
                    </tr>
                    <% end %>
                    <% if @tournament.respond_to?(:contact_email) && @tournament.contact_email.present? %>
                    <tr>
                      <td style="padding: 4px 0; color: #6b7280; font-size: 13px;">Email</td>
                      <td style="padding: 4px 0; color: #111827; font-size: 13px; font-weight: 500;">
                        <a href="mailto:<%= @tournament.contact_email %>" style="color: <%= brand %>; text-decoration: none;"><%= @tournament.contact_email %></a>
                      </td>
                    </tr>
                    <% end %>
                  </table>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <% if @prize.sponsor_name.present? %>
        <!-- Sponsor credit -->
        <tr>
          <td style="padding: 0 32px 16px;">
            <p style="margin: 0; color: #9ca3af; font-size: 12px; line-height: 1.5;">
              This prize was generously donated by <strong style="color: #6b7280;"><%= @prize.sponsor_name %></strong>.
            </p>
          </td>
        </tr>
        <% end %>

        <!-- Closing -->
        <tr>
          <td style="padding: 8px 32px 28px;">
            <p style="margin: 0; color: #4b5563; font-size: 14px; line-height: 1.6;">
              Thank you for participating in our raffle and supporting <strong style="color: #1a1a1a;"><%= @org_name %></strong>. Enjoy your prize!
            </p>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background-color: #f9fafb; border-top: 1px solid #e5e7eb; padding: 20px 32px; text-align: center;">
            <p style="margin: 0 0 4px; color: #6b7280; font-size: 12px; font-weight: 500;"><%= @org_name %></p>
            <p style="margin: 0; color: #9ca3af; font-size: 11px;">Powered by Shimizu Technology</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
