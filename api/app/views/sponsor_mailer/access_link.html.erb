<%
  brand = @primary_color || '#0057B8'
  tournament_name = @tournament&.name || 'the tournament'
  team_count = (@sponsor.slot_count.to_i / 2.0).ceil
  team_label = team_count == 1 ? '1 team' : "#{team_count} teams"
  player_count = @sponsor.slot_count.to_i
  contact_name = @tournament&.contact_name.presence || @org_name
  contact_phone = @tournament&.contact_phone
  contact_email = @tournament&.respond_to?(:contact_email) ? @tournament.contact_email : nil

  deadline_text = if @tournament&.sponsor_edit_deadline.present?
    @tournament.sponsor_edit_deadline.strftime('%B %-d, %Y at %-I:%M %p')
  elsif @tournament&.check_in_time.present? && @tournament&.event_date.present?
    "#{@tournament.check_in_time} on #{@tournament.event_date.is_a?(Date) ? @tournament.event_date.strftime('%B %-d, %Y') : @tournament.event_date}"
  else
    nil
  end
%>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background-color: #f0f2f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
  <tr>
    <td align="center" style="padding: 32px 16px;">
      <table role="presentation" width="560" cellspacing="0" cellpadding="0" style="background-color: #ffffff; border-radius: 16px; overflow: hidden; max-width: 100%;">

        <!-- Header -->
        <tr>
          <td style="background: linear-gradient(135deg, <%= brand %> 0%, <%= darken_color(brand, 25) %> 100%); padding: 32px 32px 28px; text-align: center;">
            <p style="margin: 0 0 6px; color: rgba(255,255,255,0.75); font-size: 11px; letter-spacing: 2px; text-transform: uppercase; font-weight: 600;"><%= @org_name %></p>
            <h1 style="margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; line-height: 1.3;"><%= tournament_name %></h1>
          </td>
        </tr>

        <!-- Status pill -->
        <tr>
          <td style="padding: 20px 32px 0; text-align: center;">
            <span style="display: inline-block; background-color: #dbeafe; color: <%= brand %>; padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 600;">Sponsor Portal Access</span>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding: 24px 32px 0;">
            <p style="margin: 0 0 16px; color: #1a1a1a; font-size: 17px; font-weight: 600;">Hello <%= @sponsor.name %>!</p>

            <p style="margin: 0 0 20px; color: #4b5563; font-size: 14px; line-height: 1.65;">
              Thank you for sponsoring <strong style="color: #1a1a1a;"><%= tournament_name %></strong>!
              <% if player_count > 0 %>
                You have <strong style="color: #1a1a1a;"><%= team_label %></strong> (<%= player_count %> player<%= player_count == 1 ? '' : 's' %>) to register.
              <% end %>
            </p>

            <p style="margin: 0 0 20px; color: #4b5563; font-size: 14px; line-height: 1.65;">
              Use the link below to access your sponsor portal and enter your players' information:
            </p>

            <!-- CTA Button -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom: 24px;">
              <tr>
                <td align="center">
                  <a href="<%= @access_url %>"
                     style="display: inline-block; background-color: <%= brand %>; color: #ffffff; padding: 12px 28px; border-radius: 10px; text-decoration: none; font-size: 14px; font-weight: 600;">
                    Access Sponsor Portal
                  </a>
                </td>
              </tr>
            </table>

            <% if deadline_text %>
            <!-- Deadline notice -->
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom: 24px;">
              <tr>
                <td style="background-color: #fffbeb; border: 1px solid #fde68a; border-radius: 12px; padding: 14px 18px;">
                  <p style="margin: 0; color: #92400e; font-size: 13px; line-height: 1.5;">
                    <strong>Deadline:</strong> Player information must be submitted by <strong><%= deadline_text %></strong>. After that, changes will be locked.
                  </p>
                </td>
              </tr>
            </table>
            <% end %>

            <p style="margin: 0 0 8px; color: #9ca3af; font-size: 12px; line-height: 1.5;">
              If the button doesn't work, copy and paste this link:<br>
              <span style="color: #6b7280; word-break: break-all;"><%= @access_url %></span>
            </p>
            <p style="margin: 0 0 0; color: #9ca3af; font-size: 12px;">
              This link expires in 7 days. Need a new one? Visit your sponsor portal login page.
            </p>
          </td>
        </tr>

        <!-- Contact -->
        <tr>
          <td style="padding: 20px 32px 28px;">
            <p style="margin: 0; color: #6b7280; font-size: 13px; line-height: 1.6;">
              Questions? Contact <strong style="color: #374151;"><%= contact_name %></strong><%= " at #{contact_phone}" if contact_phone.present? %><%= " or <a href=\"mailto:#{contact_email}\" style=\"color: #{brand}; text-decoration: none;\">#{contact_email}</a>".html_safe if contact_email.present? %>.
            </p>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="background-color: #f9fafb; border-top: 1px solid #e5e7eb; padding: 20px 32px; text-align: center;">
            <p style="margin: 0 0 4px; color: #6b7280; font-size: 12px; font-weight: 500;"><%= @org_name %></p>
            <p style="margin: 0; color: #9ca3af; font-size: 11px;">Powered by Shimizu Technology</p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
